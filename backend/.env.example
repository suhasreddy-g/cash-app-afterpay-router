# --- Square (Cash App Pay) ---------------------------------------------------
# Required to start the server:
SQUARE_ACCESS_TOKEN=your_sandbox_access_token
SQUARE_APP_ID=your_sandbox_application_id

# Optional Square config:
SQUARE_ENVIRONMENT=sandbox          # "sandbox" (default) or "production"
SQUARE_LOCATION_ID=                 # if blank, the first account location is used
SQUARE_CURRENCY=USD
SQUARE_REDIRECT_URL=                # where Square sends the buyer after paying
SQUARE_SUPPORT_EMAIL=

# Square webhook verification (required to verify signatures):
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=    # exact URL Square POSTs to, e.g.
                                    # https://your-host/webhooks/square

# --- Afterpay (via Square) --------------------------------------------------
# Afterpay payments are created via Square's API using test source IDs.
# No separate Afterpay credentials needed.
#
# Afterpay webhook verification (HMAC-SHA256 shared secret):
AFTERPAY_WEBHOOK_SECRET=

# --- Server ------------------------------------------------------------------
PORT=8000
